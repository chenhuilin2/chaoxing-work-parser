                                onclick="initAssistant('question215004807', '4', '简答题', '49522f5e51b24fbdadb9a8dfda95b06c', '0', 0, '52785453')"
                                class="aiAssistant"><span><i class="custom-style">AI讲解</i></span></a>
                        </div>
                    </div>
