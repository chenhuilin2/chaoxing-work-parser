    <div class="maskDiv" style="display:none;" id="workpop">
        <div class="popDiv wid440 Marking">
            <div class="popHead" id="workpopFocus" role="alertdialog" tabindex="0">
                <a id="popCloseFocus" href="javascript:;" class="popClose fr" onclick="popClickFunc()"
                    tabindex="-1"><img src="//mooc1.chaoxing.com/mooc-ans/images/popClose.png" id="popCloseFocusImg"
                        onkeydown="if(event.keyCode == 13){popCloseFocus();}" role="button" tabindex="-1"
                        aria-label="关闭" /></a>
